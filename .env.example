# ─────────────────────────────────────────────────────────────────────────────
# InstantNeed Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
DB_USERNAME=instantneed
DB_PASSWORD=changeme
# DB_URL is set automatically by docker-compose (postgres://postgres:5432/...)
# Override only if connecting to an external database:
# DB_URL=jdbc:postgresql://your-db-host:5432/instant_need

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=change-this-to-a-long-random-base64-string
JWT_ACCESS_EXPIRATION=3600000     # 1 hour in ms
JWT_REFRESH_EXPIRATION=604800000  # 7 days in ms

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Email (SMTP) ���────────────────────────────────────────────────────────────
MAIL_ENABLED=false
MAIL_FROM=noreply@instantneed.com
APP_URL=http://localhost:3000
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ── Image Storage ────────────────────────────────────────────────────────────
# Local filesystem (default — good for dev):
STORAGE_TYPE=local
# UPLOAD_DIR=./uploads          # where files are written inside the container
# STORAGE_BASE_URL=http://localhost:8080/uploads

# S3 + CloudFront (production):
# STORAGE_TYPE=s3
# S3_BUCKET=instantneed-products-images
# AWS_REGION=ap-northeast-2
# STORAGE_BASE_URL=https://<your-cloudfront-domain>.cloudfront.net
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT=                  # leave blank for real AWS; set to http://localhost:4566 for LocalStack

# ── Seed Data ────────────────────────────────────────────────────────────────
SEED_DATA=false

# ── Frontend (consumed by docker-compose build args) ─────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=InstantNeed
IMAGE_HOSTNAME=localhost
